{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "rebaseWhen": "behind-base-branch",
  "ocb": {
    "managerFilePatterns": ["/build/builder-config.yml$/"]
  },
  "packageRules": [
    {
      "description": "Group opentelemetry stable",
      "matchPackagePatterns": [
        "^go.opentelemetry.io/collector/confmap/provider"
      ],
      "datasources": [
        "go"
      ],
      "groupName": "opentelemetry-stable",
      "fetchChangeLogs": "off",
      "changelogUrl": "https://github.com/open-telemetry/opentelemetry-collector-contrib/releases"
    },
    {
      "description": "Group opentelemetry development",
      "matchPackagePatterns": [
        "^go.opentelemetry.io/collector/extension",
        "^go.opentelemetry.io/collector/exporter",
        "^go.opentelemetry.io/collector/processor",
        "^go.opentelemetry.io/collector/receiver",
        "^go.opentelemetry.io/collector/connector",
        "^github.com/open-telemetry/opentelemetry-collector-contrib"
      ],
      "datasources": [
        "go"
      ],
      "groupName": "opentelemetry-development",
      "fetchChangeLogs": "off",
      "changelogUrl": "https://github.com/open-telemetry/opentelemetry-collector/releases"
    }
  ]
}
